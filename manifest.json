{
  "manifest_version": 3,
  "name": "标签页会话管理器",
  "version": "1.0.0",
  "description": "保存和管理浏览器标签页会话，一键恢复工作环境",
  
  "permissions": [
    "tabs",
    "storage",
    "windows"
  ],
  
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.svg",
      "48": "icon48.svg",
      "128": "icon128.svg"
    },
    "default_title": "标签页会话管理器"
  },
  
  "icons": {
    "16": "icon16.svg",
    "48": "icon48.svg",
    "128": "icon128.svg"
  }
}
